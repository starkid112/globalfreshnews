</script>

<script>
document.addEventListener("click", async (e) => {
  const link = e.target.closest(".pagination a");
  if (!link) return;

  e.preventDefault();

  const url = link.getAttribute("href");

  try {
    const res = await fetch(url);
    const text = await res.text();

    // Parse HTML
    const parser = new DOMParser();
    const doc = parser.parseFromString(text, "text/html");

    // Get new posts section
    const newContent = doc.querySelector("#posts-container");

    document.querySelector("#posts-container").innerHTML =
      newContent.innerHTML;

    // Scroll to latest
    window.scrollTo({
    top: document.getElementById("latest").offsetTop - 80,
    behavior: "auto"
  });

  } catch (err) {
    console.error("Pagination error:", err);
  }
});
</script>

<script>
function updateDateTime(){
    const now = new Date();
    const options = {
        weekday: "long",
        year: "numeric",
        month: "long",
        day: "numeric",
        hour: "numeric",
        minute: "numeric",
        second: "numeric"
    };
    document.getElementById("liveDateTime").innerHTML =
        now.toLocaleString("en-US", options);
}
updateDateTime();
setInterval(updateDateTime, 1000);
</script>

<script>
function toggleDiscover(){
    const wrapper = document.querySelector(".discover-wrapper");
    const track = document.querySelector(".discover-track");
    const btn = document.querySelector(".discover-toggle");
    if(track.style.display === "none"){
        track.style.display = "flex";
        btn.innerHTML = "▲";
    } else {
        track.style.display = "none";
        btn.innerHTML = "▼";
    }
}
</script>

</body>
