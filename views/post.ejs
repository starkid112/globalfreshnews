<script>
function updateDateTime(){
    const now = new Date();
    const options = {
        weekday: "long",
        year: "numeric",
        month: "long",
        day: "numeric",
        hour: "numeric",
        minute: "numeric",
        second: "numeric"
    };
    document.getElementById("liveDateTime").innerHTML =
        now.toLocaleString("en-US", options);
}
updateDateTime();
setInterval(updateDateTime, 1000);
</script>

<script>
function toggleDiscover(){
    const wrapper = document.querySelector(".discover-wrapper");
    const track = document.querySelector(".discover-track");
    const btn = document.querySelector(".discover-toggle");
    if(track.style.display === "none"){
        track.style.display = "flex";
        btn.innerHTML = "▲";
    } else {
        track.style.display = "none";
        btn.innerHTML = "▼";
    }
}
</script>


