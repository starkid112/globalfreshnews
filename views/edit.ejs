<!DOCTYPE html>
<html>
<head>
    <!-- ✅ DYNAMIC TITLE -->
    <title>
      <%= typeof post !== "undefined" ? post.title + " | " : "" %>
      <%= setting.siteName || "Global Fresh News" %>
    </title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="/favicon.png">
    <link rel="stylesheet" href="/style.css">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- ✅ CKEditor -->
    <script src="https://cdn.ckeditor.com/ckeditor5/39.0.1/classic/ckeditor.js"></script>
</head>
<body>

<nav class="navbar">
    <div class="nav-left">
        <img src="/uploads/<%= setting.logo || 'logo.png' %>" class="logo-img">
    </div>

    <div class="nav-right">
        <a href="/admin">Dashboard</a>
        <a href="/logout">Logout</a>
    </div>
</nav>

<div class="page-header">
    <h1>Edit Post</h1>
</div>

<div class="container">
<div class="form-box">

<form action="/edit/<%= post._id %>" method="POST" enctype="multipart/form-data">

<!-- TITLE -->
<label>Post Title</label>
<input type="text" name="title" id="title" value="<%= post.title %>" required>

<!-- SLUG -->
<label>Slug</label>
<input type="text" name="slug" id="slug" value="<%= post.slug %>" required>

<!-- AUTHOR -->
<label>Author</label>
<input type="text" name="author" value="<%= post.author %>" required>

<!-- META DESCRIPTION -->
<label>Meta Description (SEO)</label>
<textarea name="metaDescription"><%= post.metaDescription || "" %></textarea>

<label>SEO Keywords</label>
<input type="text" name="keywords" value="<%= post.keywords || '' %>">

<!-- CATEGORY -->
<label>Category</label>
<select name="category" required>
<option value="Global" <%= post.category === "Global" ? "selected" : "" %>>Global</option>
<option value="Politics" <%= post.category === "Politics" ? "selected" : "" %>>Politics</option>
<option value="Health" <%= post.category === "Health" ? "selected" : "" %>>Health</option>
<option value="Tech" <%= post.category === "Tech" ? "selected" : "" %>>Tech</option>
<option value="Business" <%= post.category === "Business" ? "selected" : "" %>>Business</option>
<option value="Markets" <%= post.category === "Markets" ? "selected" : "" %>>Markets</option>
<option value="Education" <%= post.category === "Education" ? "selected" : "" %>>Education</option>
<option value="Lifestyle" <%= post.category === "Lifestyle" ? "selected" : "" %>>Lifestyle</option>
<option value="Sports" <%= post.category === "Sports" ? "selected" : "" %>>Sports</option>
<option value="Entertainment" <%= post.category === "Entertainment" ? "selected" : "" %>>Entertainment</option>
</select>

 <!-- SUBCATEGORY -->
<label>Sports Subcategory (optional)</label>

<select name="subCategory">
  <option value="">Select (only for Sports)</option>

  <option value="Football" <%= post.subCategory === 'Football' ? 'selected' : '' %>>Football</option>
  <option value="Tennis" <%= post.subCategory === 'Tennis' ? 'selected' : '' %>>Tennis</option>
  <option value="Basketball" <%= post.subCategory === 'Basketball' ? 'selected' : '' %>>Basketball</option>
  <option value="Golf" <%= post.subCategory === 'Golf' ? 'selected' : '' %>>Golf</option>
  <option value="Boxing" <%= post.subCategory === 'Boxing' ? 'selected' : '' %>>Boxing</option>
  <option value="Cricket" <%= post.subCategory === 'Cricket' ? 'selected' : '' %>>Cricket</option>
  <option value="Rugby" <%= post.subCategory === 'Rugby' ? 'selected' : '' %>>Rugby</option>
  <option value="Baseball" <%= post.subCategory === 'Baseball' ? 'selected' : '' %>>Baseball</option>
  <option value="Hockey" <%= post.subCategory === 'Hockey' ? 'selected' : '' %>>Hockey</option>
  <option value="Olympics" <%= post.subCategory === 'Olympics' ? 'selected' : '' %>>Olympics</option>
  <option value="Motorsport" <%= post.subCategory === 'Motorsport' ? 'selected' : '' %>>Motorsport</option>
</select>  

<!-- REGION -->
<label>Region (Global News Only)</label>
<select name="region" id="regionEdit">
    <option value="">Select Region</option>
    <option value="Africa" <%= post.region === "Africa" ? "selected" : "" %>>Africa</option>
    <option value="Europe" <%= post.region === "Europe" ? "selected" : "" %>>Europe</option>
    <option value="Asia" <%= post.region === "Asia" ? "selected" : "" %>>Asia</option>
    <option value="North America" <%= post.region === "North America" ? "selected" : "" %>>North America</option>
    <option value="South America" <%= post.region === "South America" ? "selected" : "" %>>South America</option>
    <option value="Middle East" <%= post.region === "Middle East" ? "selected" : "" %>>Middle East</option>
    <option value="Oceania" <%= post.region === "Oceania" ? "selected" : "" %>>Oceania</option>
</select>

<label>Country (For Global News)</label>
<select name="country">
<option value="">Select Country</option>
<optgroup label="Africa">
