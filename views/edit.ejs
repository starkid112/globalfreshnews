<option value="Thailand" <%= post.country === 'Thailand' ? 'selected' : '' %>>Thailand</option>
<option value="Vietnam" <%= post.country === 'Vietnam' ? 'selected' : '' %>>Vietnam</option>
<option value="Philippines" <%= post.country === 'Philippines' ? 'selected' : '' %>>Philippines</option>
<option value="Sri Lanka" <%= post.country === 'Sri Lanka' ? 'selected' : '' %>>Sri Lanka</option>
<option value="Nepal" <%= post.country === 'Nepal' ? 'selected' : '' %>>Nepal</option>
<option value="Mongolia" <%= post.country === 'Mongolia' ? 'selected' : '' %>>Mongolia</option>
<option value="Kazakhstan" <%= post.country === 'Kazakhstan' ? 'selected' : '' %>>Kazakhstan</option>
<option value="Uzbekistan" <%= post.country === 'Uzbekistan' ? 'selected' : '' %>>Uzbekistan</option>
</optgroup>
