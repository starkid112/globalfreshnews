<option value="Japan" <%= post.country === 'Japan' ? 'selected' : '' %>>Japan</option>
<option value="South Korea" <%= post.country === 'South Korea' ? 'selected' : '' %>>South Korea</option>
<option value="North Korea" <%= post.country === 'North Korea' ? 'selected' : '' %>>North Korea</option>
<option value="Pakistan" <%= post.country === 'Pakistan' ? 'selected' : '' %>>Pakistan</option>
<option value="Bangladesh" <%= post.country === 'Bangladesh' ? 'selected' : '' %>>Bangladesh</option>
