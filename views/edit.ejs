</select>

<!-- IMAGE -->
<label>Upload Image</label>
<input type="file" name="image">

<% if (post.image) { %>
  <img src="/uploads/<%= post.image %>" style="width:150px;">
<% } %>

<img id="preview" style="max-width:100%; margin-top:10px; display:none;">

<!-- ALT TEXT -->
<label>Image Alt Text (SEO)</label>
<input type="text" name="altText" value="<%= post.altText || '' %>">

<!-- IMAGE CAPTION -->
<label>Image Caption (Visible)</label>
<input type="text" name="caption" value="<%= post.caption || '' %>">

<!-- CONTENT -->
<label>Content</label>
<textarea name="content" id="editor" rows="8" required><%= post.content %></textarea>

<label>Feature Type</label>
<select name="featureType">
  <option value="none" <%= post.featureType === "none" ? "selected" : "" %>>None</option>
  <option value="big" <%= post.featureType === "big" ? "selected" : "" %>>Big Feature</option>
  <option value="small" <%= post.featureType === "small" ? "selected" : "" %>>Small Feature</option>
</select>

<label>
  <input type="checkbox" name="isBreaking" <%= post.isBreaking ? "checked" : "" %>>
  Mark as Breaking News
</label>

<div style="margin-top:10px;">
  <label>
    <input
      type="checkbox"
      name="isSlider"
      <%= post.isSlider ? "checked" : "" %>> Show in Happening Now Slider
  </label>
</div>

<div style="margin-top:10px;">
  <label>
    <input
      type="checkbox"
      name="isExclusiveTop"
      <%= post.isExclusiveTop ? "checked" : "" %>> Show in Exclusive News (Top)
  </label>
</div>

<div style="margin-top:10px;">
  <label>
    <input
      type="checkbox"
      name="isExclusiveMiddle"
      <%= post.isExclusiveMiddle ? "checked" : "" %>> Show in Exclusive News (Middle)
  </label>
</div>

<div style="margin-top:10px;">
  <label>
    <input
      type="checkbox" name="sponsored" <%= post.sponsored ? "checked" : "" %>> Sponsored Post
  </label>
</div>

<div style="margin-top:5px;">
    <label for="isPinned">
        <input
            type="checkbox"
            id="isPinned"
            name="isPinned"
            value="true"
            <%= post && post.isPinned ? 'checked' : '' %>>
        Pin Post To Homepage
    </label>
</div>

<div style="margin-top:10px;">
  <label>
     Pin Until
  </label>
  <input 
  type="date" 
  name="pinnedUntil"
  value="<%= post.pinnedUntil ? new Date(post.pinnedUntil).toISOString().split('T')[0] : '' %>"
>
</div>

<select name="status" required>
  <option value="published" <%= post.status === 'published' ? 'selected' : '' %>>Published</option>
  <option value="draft" <%= post.status === 'draft' ? 'selected' : '' %>>Draft</option>
</select>

<!-- SUBMIT -->
<button type="submit">Update Post</button>

</form>

</div>
</div>


<!-- 🔥 AUTO SLUG SCRIPT -->
<script>
document.getElementById("title").addEventListener("input", function() {
    let slug = this.value
        .toLowerCase()
        .trim()
        .replace(/[^a-z0-9 ]/g, "")
        .replace(/\s+/g, "-");

    document.getElementById("slug").value = slug;
});
</script>

<script>
ClassicEditor
  .create(document.querySelector("#editor"))
  .catch(error => console.error(error));
</script>

</body>
</html>