<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- FAVICON -->
    <link rel="icon" type="image/png" href="/favicon.png">

    <!-- CSS -->
    <link rel="stylesheet" href="/style.css">

    <!-- ✅ DYNAMIC TITLE -->
    <title>
      <%= typeof post !== "undefined" ? post.title + " | " : "" %>
      <%= setting.siteName || "Global Fresh News" %>
    </title>
</head>
<body>

<!-- ✅ NAVBAR (CONSISTENT DESIGN) -->
<nav class="navbar">
    <div class="nav-left">
        <img src="/uploads/<%= setting.logo || 'logo.png' %>" class="logo-img">
        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/category/Global">Global</a>
            <a href="/category/Tech">Tech</a>
            <a href="/category/Politics">Politics</a>
            <a href="/category/Health">Health</a>
            <a href="/category/Entertainment">Entertainment</a>
            <a href="/category/Sports">Sports</a>
        </div>
    </div>
</nav>

<!-- ✅ LOGIN CONTAINER -->
<div class="login-container">

    <h2>Admin Login</h2>

    <!-- ✅ SUCCESS MESSAGE (PUT IT HERE) -->
    <% if (typeof req !== "undefined" && req.query.reset === "success") { %>
        <p style="color:green; margin-bottom:10px;">
            ✅ Password reset successful. You can now login.
        </p>
    <% } %>

    <form action="/login" method="POST" class="login-form">

        <input 
            type="text" 
            name="username" 
            placeholder="Username" 
            required
        >

        <input 
            type="password" 
            name="password" 
            placeholder="Password" 
            required
        >

        <button type="submit">Login</button>

    </form>

    <div style="display:flex; justify-content:space-between; margin-top:10px;">
        <a href="/forgot-password">Forgot Password?</a>
        <a href="/admin/register">Sign Up</a>
    </div>

</div>

</body>
</html>