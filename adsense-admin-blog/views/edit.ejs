<!DOCTYPE html>
<html>
<head>
    <title>Edit Post</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<h1>Edit Post</h1>

<form action="/edit/<%= post._id %>" method="POST">
    <input type="text" name="title" value="<%= post.title %>" required><br><br>
    <input type="file" name="image"><br><br>
    
    <textarea name="content" rows="10" cols="50" required><%= post.content %></textarea><br><br>
    <form action="/edit/<%= post._id %>?password=1234" method="POST" enctype="multipart/form-data"></form>
    
    <button type="submit">Update</button>
</form>

</body>
</html>